  {:id :heat-wave :start-hour 80 :duration 12 :condition-multipliers {:cardio 1.5} :arrival-multiplier 1.0}
  {:id :hurricane :start-hour 120 :duration 14 :condition-multipliers {:psych 2.0} :arrival-multiplier 1.0}
  {:id :outbreak-mild :start-hour 140 :duration 12 :condition-multipliers {:respiratory 2.0} :arrival-multiplier 1.0}
  {:id :outbreak-severe :start-hour 156 :duration 8 :condition-multipliers {:respiratory 10.0} :arrival-multiplier 1.05}]}
